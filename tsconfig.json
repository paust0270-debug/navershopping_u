{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "declaration": false
  },
  "include": [
    "unified-runner.ts",
    "ipRotation.ts",
    "engine-config.ts",
    "captcha/**/*.ts",
    "shared/**/*.ts"
  ],
  "exclude": ["node_modules"]
}

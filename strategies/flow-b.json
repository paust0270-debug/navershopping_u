{
  "version": 1,
  "name": "flow-b-template",
  "description": "B 전략 템플릿. 메인 키워드만으로 검색하는 단순 클릭 흐름.",
  "runtime": {
    "workMode": "mobile",
    "search": {
      "searchFlowVersion": "B",
      "maxScrollAttempts": 4
    },
    "taskSource": {
      "taskFilePath": "engine-next-task.json",
      "resultFilePath": "engine-last-result.json"
    }
  },
  "tasks": [
    {
      "checked": true,
      "keyword": "예시 메인 키워드",
      "linkUrl": "https://smartstore.naver.com/example/products/1234567890",
      "targetCount": 10
    }
  ]
}

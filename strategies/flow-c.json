{
  "version": 1,
  "name": "flow-c-template",
  "description": "C 전략 템플릿. 2차 키워드만 사용하는 흐름이라 keywordName이 필수다.",
  "runtime": {
    "workMode": "mobile",
    "search": {
      "searchFlowVersion": "C",
      "maxScrollAttempts": 4
    },
    "taskSource": {
      "taskFilePath": "engine-next-task.json",
      "resultFilePath": "engine-last-result.json"
    }
  },
  "tasks": [
    {
      "checked": true,
      "keyword": "예시 메인 키워드",
      "linkUrl": "https://smartstore.naver.com/example/products/1234567890",
      "keywordName": "예시 2차 키워드",
      "targetCount": 10
    }
  ]
}

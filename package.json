{
  "name": "turafic-auto-updater",
  "version": "1.0.0",
  "description": "TURAFIC 자동 업데이트 시스템 - 1000대 PC에 한 번만 배포",
  "main": "auto-updater.js",
  "bin": "auto-updater.js",
  "scripts": {
    "build": "esbuild auto-updater.ts --bundle --platform=node --target=node18 --outfile=auto-updater.js",
    "build:worker": "esbuild unified-runner.ts --bundle --platform=node --target=node18 --format=cjs --external:playwright --external:puppeteer-real-browser --external:puppeteer --external:@anthropic-ai/sdk --external:@supabase/supabase-js --outfile=worker-runner.js",
    "build:launcher": "esbuild launcher.ts --bundle --platform=node --target=node18 --outfile=dist/launcher.js",
    "build:launcher-dev": "node -e \"const fs=require('fs');let c=fs.readFileSync('launcher.ts','utf8');c=c.replace(/GIT_BRANCH = 'main'/,\\\"GIT_BRANCH = 'develop'\\\");fs.writeFileSync('launcher-dev.ts',c);\" && esbuild launcher-dev.ts --bundle --platform=node --target=node18 --outfile=dist/launcher-dev.js",
    "build:all": "npm run build && npm run build:worker && npm run build:launcher",
    "build:exe": "npm run build && pkg auto-updater.js -t node18-win-x64 -o turafic-updater.exe",
    "build:launcher-exe": "npm run build:launcher && pkg dist/launcher.js -t node18-win-x64 -o turafic-launcher.exe",
    "build:launcher-exe-dev": "npm run build:launcher-dev && pkg dist/launcher-dev.js -t node18-win-x64 -o turafic-launcher-dev.exe",
    "build:all-exe": "npm run build:launcher-exe && npm run build:launcher-exe-dev",
    "start": "node auto-updater.js",
    "dev": "tsx auto-updater.ts",
    "launcher": "tsx launcher.ts"
  },
  "pkg": {
    "scripts": "auto-updater.js",
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist",
    "assets": []
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@supabase/supabase-js": "^2.86.2",
    "dotenv": "^16.0.0",
    "playwright": "^1.57.0",
    "puppeteer-real-browser": "^1.4.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.19.0",
    "pkg": "^5.8.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}

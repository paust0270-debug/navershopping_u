{
  "name": "sellermate-unified-runner",
  "version": "1.0.0",
  "private": true,
  "description": "unified-runner — 엔진 JSON 입출력, Patchright",
  "scripts": {
    "start": "npx tsx unified-runner.ts",
    "once": "npx tsx unified-runner.ts --once",
    "build:worker": "esbuild unified-runner.ts --bundle --platform=node --target=node18 --format=cjs --external:patchright --external:@anthropic-ai/sdk --outfile=worker-runner.js",
    "build:gui-exe": "npm run build:worker && cd traffic-engine-gui && npm install && npm run pack"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "dotenv": "^16.0.0",
    "patchright": "^1.49.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.19.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}

NETWORK_RECONNECT_TIMEOUT=10
VERIFY_IP_CHANGE=true

# 순위 체크 설정
RANK_CHECK_DELAY=1800
RANK_CHECK_MAX_PAGE=10

# 데이터 저장 설정
DATA_STORAGE_TYPE=json
DATA_BACKUP_ENABLED=true
DATA_BACKUP_TIME=00:00

# 성능 모니터링

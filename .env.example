# ADB 설정
ADB_DEVICE_ID=
ADB_WIRELESS=false
ADB_IP=

# 자동화 모드 선택
AUTOMATION_MODE=adb
APPIUM_SERVER=http://localhost:4723
CHROME_DEBUG_PORT=9222

# 로깅 설정
LOG_LEVEL=INFO
LOG_FILE_ENABLED=true
LOG_FILE_PATH=./logs/navertrafic.log

# 테스트 설정
TEST_ITERATIONS=100
STAY_DURATION_MIN=30
STAY_DURATION_MAX=60
SCROLL_PROBABILITY=0.7
ACTION_WAIT_MIN=2.0
ACTION_WAIT_MAX=5.0

# 액션 확률 분포
ACTION_CART_PROBABILITY=0.3
ACTION_REVIEW_PROBABILITY=0.4
ACTION_QNA_PROBABILITY=0.2
ACTION_BROWSE_PROBABILITY=0.1

# IP 변경 설정
